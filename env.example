# --- CrowdSec LAPI ---
LAPI_BASE=http://crowdsec:8080/v1

# Credentials de la machine créée à l'étape 1
CS_MACHINE_ID=
CS_PASSWORD=CHANGE_ME

LOOKBACK=13h

# --- GitHub ---
GH_TOKEN=CHANGE_ME
GH_OWNER=USERNAME
GH_REPO=REPO_NAME
GH_BRANCH=main

# --- Feed ---
TTL_DAYS=7

# --- MISP (optional) ---
MISP_URL=https://misp
MISP_KEY=CHANGE_ME
MISP_VERIFY_SSL=true

# UUIDs des 3 events MISP rolling (un par scope de feed).
# - MISP_UUID_ALL      : event historique, contient TOUTES les IPs (toutes
#                        sources) — = ce que `crowdsec_7d.*` contenait jusqu'ici.
# - MISP_UUID_CROWDSEC : event scopé aux IPs vues par CrowdSec.
# - MISP_UUID_SURICATA : event scopé aux IPs vues par Suricata.
# Une IP multi-source apparaît dans les 3 events (corrélation MISP côté
# instance qui consomme).
# Les UUIDs doivent être stables : changer une valeur = créer un nouvel event
# côté instance MISP (perte de l'historique précédent).
MISP_UUID_ALL=d177856e-6e46-44ee-8eb5-83ef1c7452c7
MISP_UUID_CROWDSEC=6a10e5d8-f1cd-42b0-8240-a4650efd83d6
MISP_UUID_SURICATA=8f09de10-6867-45c6-814d-3d91a33d3af7

# --- Suricata via Splunk (optional) ---
# Laisser SURICATA_ENABLED=false pour désactiver complètement la source.
# Le token Splunk doit être attaché à un rôle limité (lecture de l'index
# block uniquement, capability `search` seulement) — voir README.
SURICATA_ENABLED=false
SPLUNK_URL=
SPLUNK_TOKEN=CHANGE_ME
SPLUNK_INDEX_BLOCK=suricata_block
# Index eve (JSON complet des alertes Suricata : URL, méthode HTTP, payload_printable)
# Utilisé pour enrichir les IPs du feed avec un aperçu du payload observé.
SPLUNK_INDEX_EVE=suricata_eve
SPLUNK_LOOKBACK=13h
SPLUNK_VERIFY_SSL=true
# Filtre optionnel : ne garder que les events dont la priorité Suricata est
# <= à ce seuil. En Suricata, priorité plus petite = plus sévère.
# Vide = pas de filtre, on prend tout ce qui bloque.
SURICATA_MIN_PRIORITY=

# --- Sanitization PII des payloads ---
# Les payloads HTTP (URL, verbe, payload_printable) capturés par CrowdSec et
# Suricata peuvent contenir des indices sur l'infrastructure cible
# (IP publique, nom d'hôte privé). Avant publication sur le feed ou dans
# MISP, toutes les occurrences listées ci-dessous sont remplacées par des
# tokens [REDACTED_IP] / [REDACTED_DOMAIN].
#
# Syntaxe :
# - IPs : liste séparée par virgule, ex "203.0.113.42,10.42.0.1"
# - Domaines : *.example.com matche l'apex + tous les sous-domaines ;
#              example.com matche uniquement l'apex
PII_IPS=
PII_DOMAINS=
# Longueur max d'un payload après sanitization (au-delà, tronqué + "…").
PAYLOAD_MAX_LEN=512
# Nombre de payloads max conservés par (IP, source) dans la DB. Au-delà on
# évince les plus anciens (FIFO).
PAYLOADS_PER_SOURCE_CAP=20
# Nombre de payloads inclus dans le commentaire MISP (les plus récents).
PAYLOADS_MISP_SHOW=3

# --- Enrichissement Tor exit-nodes (optional) ---
# Tagge les IPs du feed qui sont des exit-nodes Tor connus avec
# `tor:exit-node`. Source : check.torproject.org/exit-addresses (liste
# officielle). Fetch à chaque run (best-effort, fallback silencieux).
TOR_ENABLED=true
# Override optionnels (défauts OK dans la plupart des cas)
# TOR_EXIT_URL=https://check.torproject.org/exit-addresses
# TOR_FETCH_TIMEOUT=30

# --- Enrichissement ASN (optional) ---
# IP → ASN+prefix via CIRCL IP-ASN-History (pas d'auth).
# ASN → nom (holder) via RIPE Stat (pas d'auth).
# Désactiver si l'accès sortant est contraint ou si tu préfères une autre source.
ASN_ENABLED=true
# Overrides CIRCL (défauts OK dans 99% des cas)
# CIRCL_ASN_URL=https://bgpranking-ng.circl.lu/ipasn_history/mass_query
# CIRCL_ASN_TIMEOUT=30
# CIRCL_ASN_BATCH_SIZE=500
# Décalage en jours de la date de requête CIRCL (leur base peut être vide
# pour le jour courant — un décalage de quelques jours garantit une réponse).
# CIRCL_ASN_DATE_OFFSET_DAYS=3
# Overrides RIPE Stat (nom du holder, ex: GOOGLE, CLOUDFLARENET)
# RIPE_STAT_URL=https://stat.ripe.net/data/as-overview/data.json
# RIPE_STAT_TIMEOUT=10
